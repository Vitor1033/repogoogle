{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["email", "name", "createdAt", "updatedAt"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A saved opportunity",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "opportunityId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "opportunityId", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "A user's saved search preference for email alerts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "searchQuery": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "category", "searchQuery", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/users/{userId}/favorites/{opportunityId}": {
      "schema": { "$ref": "Favorite" },
      "description": "User's saved opportunities"
    },
    "/users/{userId}/subscriptions/{subscriptionId}": {
      "schema": { "$ref": "Subscription" },
      "description": "User's email alert subscriptions"
    }
  }
}
