rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'createdAt', 'updatedAt']) 
          && data.keys().size() <= 4
          && data.email is string && data.email.size() <= 256
          && data.name is string && data.name.size() <= 256
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['userId', 'opportunityId', 'createdAt'])
          && data.keys().size() <= 3
          && data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
          && data.opportunityId is string && data.opportunityId.size() <= 128
          && data.createdAt is timestamp;
    }

    function isValidSubscription(data) {
      return data.keys().hasAll(['userId', 'category', 'searchQuery', 'createdAt'])
          && data.keys().size() <= 4
          && data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
          && data.category is string && data.category.size() <= 256
          && data.searchQuery is string && data.searchQuery.size() <= 256
          && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isVerified() && isValidId(userId) && request.auth.uid == userId;
      
      allow create: if isVerified() && isValidId(userId) && request.auth.uid == userId
                    && isValidUser(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      
      allow update: if isVerified() && isValidId(userId) && request.auth.uid == userId
                    && isValidUser(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'updatedAt']);
                    
      match /favorites/{opportunityId} {
        allow get: if isVerified() && isValidId(userId) && request.auth.uid == userId && isValidId(opportunityId);
        
        allow list: if isVerified() && isValidId(userId) && request.auth.uid == userId;
        
        allow create: if isVerified() && isValidId(userId) && request.auth.uid == userId && isValidId(opportunityId)
                      && isValidFavorite(incoming())
                      && incoming().userId == request.auth.uid
                      && incoming().opportunityId == opportunityId
                      && incoming().createdAt == request.time;
        
        allow delete: if isVerified() && isValidId(userId) && request.auth.uid == userId && isValidId(opportunityId);
      }

      match /subscriptions/{subscriptionId} {
        allow get: if isVerified() && isValidId(userId) && request.auth.uid == userId && isValidId(subscriptionId);
        
        allow list: if isVerified() && isValidId(userId) && request.auth.uid == userId;
        
        allow create: if isVerified() && isValidId(userId) && request.auth.uid == userId && isValidId(subscriptionId)
                      && isValidSubscription(incoming())
                      && incoming().userId == request.auth.uid
                      && incoming().createdAt == request.time;
        
        allow delete: if isVerified() && isValidId(userId) && request.auth.uid == userId && isValidId(subscriptionId);
      }
    }

  }
}
